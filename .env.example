# --- LLM for JD extraction + resume tailoring (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# ==========================================================================
# MEMORY SPINE — pick one. Default (no vars) = LocalMemory (in-process).
# ==========================================================================

# (A) Hosted Cognee via REST (persistent, recommended). App uses CogneeRestMemory.
# COGNEE_BASE_URL=https://tenant-xxxx.aws.cognee.ai
# COGNEE_API_KEY=...
# If your local resolver REFUSES the tenant hostname, pin its IP (TLS SNI stays intact):
# COGNEE_RESOLVE_IP=54.197.228.131

# (B) Force the offline in-process double (tests / no network):
# APPLY_AI_MEMORY=local

# --- Embedded Cognee (BROKEN on this machine: missing ladybug native lib) ---
# Left here only for reference; do not use until a graph backend works.
# GRAPH_DATABASE_PROVIDER=kuzu
# LLM_API_KEY=sk-...
# EMBEDDING_API_KEY=sk-...
# ENABLE_BACKEND_ACCESS_CONTROL=false
# COGNEE_SKIP_CONNECTION_TEST=true
