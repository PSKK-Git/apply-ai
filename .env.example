# ==========================================================================
# GENERATOR LLM — used for JD extraction + resume tailoring (apply_ai/llm.py).
# Pick ONE provider. All of this is also changeable live from the app sidebar.
# ==========================================================================
APPLY_AI_GEN_PROVIDER=gemini      # gemini | claude | mistral | openai | ollama | openrouter | custom
APPLY_AI_GEN_MODEL=               # optional override; each provider has a sane default

GEMINI_API_KEY=                   # provider=gemini    (default model: gemini-2.5-flash)
ANTHROPIC_API_KEY=sk-ant-...      # provider=claude    (default model: claude-sonnet-5)
MISTRAL_API_KEY=                  # provider=mistral   (default model: mistral-small-latest)
OPENAI_API_KEY=                   # provider=openai    (default model: gpt-4o-mini)

# provider=ollama — free, local, no key. Requires `ollama pull <model>` first.
OLLAMA_BASE_URL=http://localhost:11434/v1

# provider=openrouter | custom — any OpenAI-compatible gateway.
APPLY_AI_CUSTOM_BASE_URL=https://openrouter.ai/api/v1
APPLY_AI_CUSTOM_KEY=sk-or-...
# APPLY_AI_GEN_MODEL=meta-llama/llama-3.3-70b-instruct:free   # must be a TEXT model, not image

# ==========================================================================
# MEMORY SPINE — the grounding/retrieval backend. Default = Cognee.
# ==========================================================================

# (A) Hosted Cognee via REST (persistent, recommended). App uses CogneeRestMemory.
COGNEE_BASE_URL=https://tenant-xxxx.aws.cognee.ai
COGNEE_API_KEY=...
# If your local resolver REFUSES the tenant hostname, pin its IP (TLS SNI stays intact):
# COGNEE_RESOLVE_IP=54.197.228.131

# (B) Force the offline in-process double (tests / no network / no Cognee account):
# APPLY_AI_MEMORY=local

# --- Embedded Cognee (BROKEN on macOS: missing ladybug native lib) ---
# Left here only for reference; do not use until a graph backend works.
# GRAPH_DATABASE_PROVIDER=kuzu
# LLM_API_KEY=sk-...
# EMBEDDING_API_KEY=sk-...
# ENABLE_BACKEND_ACCESS_CONTROL=false
# COGNEE_SKIP_CONNECTION_TEST=true
